// Snaptie — Schema da base de dados (Passo 1)
// Plataforma de QR Codes interativos multi-empresa.
// Lógica: uma empresa cria QRs -> cada QR tem botões (blocks) -> cada scan é registado.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // ligação pooled (usada pela aplicação)
  directUrl = env("DIRECT_URL") // ligação direta (usada em migrações)
}

// ----------------------------------------------------------------------------
// ENUMS
// ----------------------------------------------------------------------------

enum UserRole {
  ADMIN // Acesso total à plataforma (Snaptie)
  GESTOR_EMPRESA // Gere uma empresa cliente
  GESTOR_QR // Gere QR Codes e conteúdos
  VISUALIZADOR // Apenas consulta
}

enum UserStatus {
  ATIVO // Pode utilizar normalmente
  INATIVO // Não pode iniciar sessão
  SUSPENSO // Conta temporariamente bloqueada
}

enum CompanyStatus {
  ATIVA // Pode utilizar a plataforma normalmente
  SUSPENSA // Não pode criar nem alterar conteúdos
  INATIVA // Conta desativada
}

enum Plano {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ATIVA
  CANCELADA
  EXPIRADA
  PENDENTE
}

// Tipos de botão (block). Os primeiros já são suportados; os restantes ficam
// preparados para evoluir sem alterar o schema.
enum BlockType {
  // Elementos de ação (apresentados como botões)
  TEXTO
  LINK
  WHATSAPP
  TELEFONE
  EMAIL
  MAPA
  WIFI
  PDF
  // Elementos de conteúdo (apresentados diretamente na página)
  IMAGEM
  CARROSSEL
  VIDEO
  // Tipos futuros
  CHAT
  FEED
  FORMULARIO
  GALERIA
  PLAYLIST
}

// ----------------------------------------------------------------------------
// MODELOS
// ----------------------------------------------------------------------------

// Utilizadores da plataforma (admin Snaptie, gestores e funcionários das empresas)
model User {
  id         String     @id @default(cuid())
  nome       String
  email      String     @unique
  password   String // hash bcrypt — nunca a password em claro
  role       UserRole   @default(VISUALIZADOR)
  status     UserStatus @default(ATIVO)
  companyId  String?    @map("company_id")
  ultimoLogin DateTime? @map("ultimo_login")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@map("users")
}

// Empresas clientes da plataforma
model Company {
  id            String        @id @default(cuid())
  nome          String
  slug          String        @unique
  logo          String?
  email         String
  telefone      String?
  website       String?
  corPrimaria   String?       @map("cor_primaria")
  corSecundaria String?       @map("cor_secundaria")
  estado        CompanyStatus @default(ATIVA)
  plano         Plano         @default(FREE)
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  deletedAt     DateTime?     @map("deleted_at") // soft delete

  users         User[]
  qrCodes       QrCode[]
  files         File[]
  subscriptions Subscription[]

  @@map("companies")
}

// Cada QR criado na plataforma
model QrCode {
  id            String   @id @default(cuid())
  nome          String
  descricao     String?
  slug          String   @unique
  companyId     String   @map("company_id")
  templateId    String?  @map("template_id")
  logo          String?
  imagemCapa    String?  @map("imagem_capa") // imagem horizontal no topo da página
  logoTamanho   String   @default("M") @map("logo_tamanho") // P, M, G
  logoForma     String   @default("circulo") @map("logo_forma") // quadrado, circulo
  nomeTamanho   String   @default("M") @map("nome_tamanho") // P, M, G
  mostrarLogo   Boolean  @default(true) @map("mostrar_logo")
  mostrarNome   Boolean  @default(true) @map("mostrar_nome")
  corPrimaria   String?  @map("cor_primaria")
  corSecundaria String?  @map("cor_secundaria")
  estado        String   @default("rascunho") // ex.: rascunho, ativo, arquivado
  publicado     Boolean  @default(false)
  scansTotal    Int      @default(0) @map("scans_total")
  ultimoScan    DateTime? @map("ultimo_scan")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  template  Template?  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  blocks    QrBlock[]
  analytics Analytics[]

  @@index([companyId])
  @@index([templateId])
  @@map("qr_codes")
}

// Elementos apresentados quando alguém faz scan de um QR (ações e conteúdos)
model QrBlock {
  id        String    @id @default(cuid())
  qrId      String    @map("qr_id")
  tipo      BlockType
  titulo    String
  icone     String?
  cor       String? // cor opcional do elemento (sobrepõe a cor primária do QR)
  descricao String? // descrição opcional do elemento
  conteudo  Json? // conteúdo flexível conforme o tipo (url, texto, ficheiro, etc.)
  ordem     Int       @default(0)
  ativo     Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  qr QrCode @relation(fields: [qrId], references: [id], onDelete: Cascade)

  @@index([qrId])
  @@map("qr_blocks")
}

// Modelos reutilizáveis para acelerar a criação de novos QRs
model Template {
  id            String   @id @default(cuid())
  nome          String
  categoria     String?
  icone         String?
  preview       String?
  estruturaJson Json?    @map("estrutura_json")
  ativo         Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")

  qrCodes QrCode[]

  @@map("templates")
}

// Ficheiros enviados para a plataforma (fotos, PDFs, vídeos, documentos)
model File {
  id        String   @id @default(cuid())
  companyId String   @map("company_id")
  nome      String
  tipo      String // mime type ou categoria (imagem, pdf, video...)
  url       String
  tamanho   Int // bytes
  createdAt DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("files")
}

// Registo de scans realizados pelos visitantes
model Analytics {
  id               String   @id @default(cuid())
  qrId             String   @map("qr_id")
  dataHora         DateTime @default(now()) @map("data_hora")
  pais             String?
  cidade           String?
  idioma           String?
  dispositivo      String?
  navegador        String?
  sistemaOperativo String?  @map("sistema_operativo")
  ip               String?

  qr QrCode @relation(fields: [qrId], references: [id], onDelete: Cascade)

  @@index([qrId])
  @@index([dataHora])
  @@map("analytics")
}

// Planos/subscrições das empresas (faturação futura)
model Subscription {
  id          String             @id @default(cuid())
  companyId   String             @map("company_id")
  plano       Plano              @default(FREE)
  limiteQrs   Int?               @map("limite_qrs")
  valorMensal Decimal?           @map("valor_mensal") @db.Decimal(10, 2)
  estado      SubscriptionStatus @default(ATIVA)
  dataInicio  DateTime           @default(now()) @map("data_inicio")
  dataFim     DateTime?          @map("data_fim")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("subscriptions")
}
