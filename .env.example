# PostgreSQL connection strings
# Pooled connection used by the application at runtime
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
# Direct connection (no connection pooler) used by Prisma for migrations
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# Secret used to sign session tokens (JWT). Generate one with:
# node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET="replace-with-a-long-random-string"

# File storage (S3-compatible, e.g. Cloudflare R2)
R2_ENDPOINT="https://<account>.r2.cloudflarestorage.com"
R2_BUCKET="your-bucket"
R2_PREFIX="snaptie"
R2_ACCESS_KEY_ID="your-access-key-id"
R2_SECRET_ACCESS_KEY="your-secret-access-key"
R2_PUBLIC_URL="https://cdn.example.com"

# Transactional email (Resend)
RESEND_API_KEY="re_xxxxxxxx"
EMAIL_FROM="noreply@example.com"
# Public base URL used in email links
APP_URL="http://localhost:3000"
